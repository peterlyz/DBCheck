{
  "chapters": [
    {
      "chapter_number": 1,
      "chapter_title_zh": "数据库版本信息",
      "chapter_title_en": "Database Version Information",
      "queries": [
        {
          "key": "mongodb_version",
          "desc_zh": "MongoDB 版本信息",
          "desc_en": "MongoDB Version Information",
          "command": "db.buildInfo()",
          "category": "basic"
        }
      ]
    },
    {
      "chapter_number": 2,
      "chapter_title_zh": "服务器状态",
      "chapter_title_en": "Server Status",
      "queries": [
        {
          "key": "mongodb_server_status",
          "desc_zh": "服务器运行状态",
          "desc_en": "Server Running Status",
          "command": "db.serverStatus()",
          "category": "basic"
        },
        {
          "key": "mongodb_connections",
          "desc_zh": "当前连接数",
          "desc_en": "Current Connections",
          "command": "db.serverStatus().connections",
          "category": "performance"
        },
        {
          "key": "mongodb_memory",
          "desc_zh": "内存使用情况",
          "desc_en": "Memory Usage",
          "command": "db.serverStatus().mem",
          "category": "performance"
        }
      ]
    },
    {
      "chapter_number": 3,
      "chapter_title_zh": "数据库统计",
      "chapter_title_en": "Database Statistics",
      "queries": [
        {
          "key": "mongodb_db_stats",
          "desc_zh": "数据库统计信息",
          "desc_en": "Database Statistics",
          "command": "db.stats()",
          "category": "basic"
        },
        {
          "key": "mongodb_collections",
          "desc_zh": "集合列表",
          "desc_en": "Collection List",
          "command": "db.getCollectionNames()",
          "category": "basic"
        }
      ]
    },
    {
      "chapter_number": 4,
      "chapter_title_zh": "安全配置",
      "chapter_title_en": "Security Configuration",
      "queries": [
        {
          "key": "mongodb_users",
          "desc_zh": "用户列表",
          "desc_en": "User List",
          "command": "db.getUsers()",
          "category": "security"
        },
        {
          "key": "mongodb_roles",
          "desc_zh": "角色列表",
          "desc_en": "Role List",
          "command": "db.getRoles({showBuiltinRoles: true})",
          "category": "security"
        }
      ]
    },
    {
      "chapter_number": 5,
      "chapter_title_zh": "性能指标",
      "chapter_title_en": "Performance Metrics",
      "queries": [
        {
          "key": "mongodb_opcounters",
          "desc_zh": "操作计数器",
          "desc_en": "Operation Counters",
          "command": "db.serverStatus().opcounters",
          "category": "performance"
        },
        {
          "key": "mongodb_global_lock",
          "desc_zh": "全局锁状态",
          "desc_en": "Global Lock Status",
          "command": "db.serverStatus().globalLock",
          "category": "performance"
        },
        {
          "key": "mongodb_wired_tiger",
          "desc_zh": "WiredTiger 存储引擎状态",
          "desc_en": "WiredTiger Storage Engine Status",
          "command": "db.serverStatus().wiredTiger",
          "category": "performance"
        }
      ]
    },
    {
      "chapter_number": 6,
      "chapter_title_zh": "复制集状态",
      "chapter_title_en": "Replica Set Status",
      "queries": [
        {
          "key": "mongodb_repl_status",
          "desc_zh": "复制集状态",
          "desc_en": "Replica Set Status",
          "command": "rs.status()",
          "category": "high_availability",
          "condition": "db.isMaster().setName != null"
        }
      ]
    }
  ]
}
